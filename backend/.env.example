# Example environment variables for backend
# Copy this file to `.env` and fill the values for your environment.

# App
PORT=5000
NODE_ENV=development
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRE=7d

# MongoDB
MONGO_URI=mongodb://localhost:27017/medibook

# SMTP (for real email delivery) - optional for local development
# If you don't set SMTP_* values, the app will log email contents instead of sending.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="MediBook <no-reply@example.com>"

# Notes:
# - For Gmail SMTP use: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587 (or 465 for SSL), set SMTP_USER and SMTP_PASS.
# - For production use a transactional email provider (SendGrid, Mailgun, Amazon SES).
# - Storing secrets in environment variables is recommended; don't commit real secrets to git.
